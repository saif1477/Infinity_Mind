{
  "name": "infinity-mind",
  "version": "0.1.0",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "tsc -p electron/tsconfig.json && concurrently \"npm run dev\" \"electron .\"",
